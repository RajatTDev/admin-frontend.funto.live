# Vola Party Admin - Frontend Environment Variables
# In Vite, only variables prefixed with VITE_ are exposed to client-side code.

# Backend API base URL (must end with a trailing slash, e.g. http://localhost:5000/)
VITE_BASE_URL=https://admin.funto.live/

# API key required by the backend for admin requests
VITE_KEY=incodes

# Project display name
VITE_PROJECT_NAME=Funto Admin
